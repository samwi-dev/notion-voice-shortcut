# 語音備忘錄 → Notion 設定檔
# 複製此檔案為 .env 並填入實際值（此檔案不含真實金鑰，可安全提交）

# Notion Integration Token（從 notion.so/my-integrations 取得）
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion Database ID（從 Database URL 取得，去掉所有 - 符號）
NOTION_DATABASE_ID=340a0e5b9b3580ca8a58e6a51b606e4e

# Notion API Version（固定不變）
NOTION_VERSION=2022-06-28

# Notion API Endpoint（固定不變）
NOTION_ENDPOINT=https://api.notion.com/v1/pages
